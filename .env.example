##############################################
# n8n Environment Configuration
# https://docs.n8n.io/hosting/installation/
##############################################

# General
GENERIC_TIMEZONE=Asia/Manila
N8N_PROTOCOL=http

# Security
# Generate a random secure key:
# openssl rand -base64 32
N8N_ENCRYPTION_KEY="yourStrongEncryptionKeyHere"
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
N8N_GIT_NODE_DISABLE_BARE_REPOS=true

# Basic Auth (Recommended even for local use)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=superSecurePassword123

# Set this to true in production
N8N_SECURE_COOKIE=false

# Host configuration
# Set N8N_HOST to your production domain (e.g., n8n.yourdomain.com)
N8N_HOST=n8n.localhost
WEBHOOK_URL=http://${N8N_HOST}/

# Folder for persistent data inside container
DATA_FOLDER=/home/node/.n8n

# Database configuration
DB_SQLITE_POOL_SIZE=5

# Task runners (improves performance and stability)
N8N_RUNNERS_ENABLED=true

# Execution mode - DEPRECATED: No longer needed, removed
# EXECUTIONS_PROCESS=main


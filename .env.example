##############################################
# n8n + PostgreSQL Configuration
# https://docs.n8n.io/hosting/installation/
##############################################

# General Settings
GENERIC_TIMEZONE=Asia/Manila
N8N_PROTOCOL=https
N8N_HOST=n8n.localhost
WEBHOOK_URL=https://${N8N_HOST}/
DATA_FOLDER=/home/node/.n8n

# Security Settings
# Generate a random secure key:
# openssl rand -base64 32
N8N_ENCRYPTION_KEY=yourStrongEncryptionKeyHere
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS=true
N8N_BLOCK_ENV_ACCESS_IN_NODE=true
N8N_GIT_NODE_DISABLE_BARE_REPOS=true
N8N_SECURE_COOKIE=false

# Basic Authentication
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=superSecurePassword123

# PostgreSQL Database
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=a/TTfzmlHA60i0gkfaso+u4vkhbHKDG0GHM+f3K5OZU=
DB_POSTGRESDB_SCHEMA=public
DB_POSTGRESDB_POOL_SIZE=10

# Performance
N8N_RUNNERS_ENABLED=true

##############################################
# DOCUMENTATION ONLY - Example Google OAuth
# (Not used unless configured in n8n)
##############################################

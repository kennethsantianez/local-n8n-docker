##############################################
# n8n Environment Configuration
# https://docs.n8n.io/hosting/installation/
##############################################

# General
GENERIC_TIMEZONE=Asia/Manila
N8N_PORT=5678
N8N_PROTOCOL=http

# Security
# Generate a random secure key:
# openssl rand -base64 32
N8N_ENCRYPTION_KEY=yourStrongEncryptionKeyHere

# Basic Auth (Recommended even for local use)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=superSecurePassword123

# Host configuration
WEBHOOK_URL=http://localhost:5678/
N8N_HOST=n8n.local

# Folder for persistent data inside container
DATA_FOLDER=/home/node/.n8n

# Execution mode (regular is fine for local)
EXECUTIONS_PROCESS=main

